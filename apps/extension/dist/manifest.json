{
  "manifest_version": 3,
  "name": "Polyglot Live Translator",
  "version": "1.0.0",
  "description": "Sous-titres traduits avec autorisation explicite de l'utilisateur.",
  "permissions": ["activeTab", "storage", "tabCapture", "scripting", "offscreen"],
  "host_permissions": ["http://127.0.0.1/*", "ws://127.0.0.1/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'self'; connect-src ws://127.0.0.1:*" },
  "action": { "default_popup": "popup.html", "default_title": "Polyglot Live Translator" },
  "content_scripts": [{ "matches": ["http://*/*", "https://*/*"], "js": ["content.js"], "run_at": "document_idle" }]
}
